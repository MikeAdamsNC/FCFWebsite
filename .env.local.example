# Copy this to .env.local for local admin testing.
# DO NOT commit .env.local (it's in .gitignore).
# In production, set these in Cloudflare Pages env vars instead.

# Admin shared password (the one you type at /admin/login).
ADMIN_PASSWORD=change-me-to-a-strong-passphrase

# 32+ byte random hex, used to HMAC-sign admin session cookies.
# Generate with: openssl rand -hex 32
AUTH_SECRET=dev-secret-not-for-production-please-rotate

# GitHub repo to commit content changes to (owner/name).
GITHUB_REPO=yourusername/fuster-cluck-farm

# Default branch (optional, defaults to main).
GITHUB_BRANCH=main

# Fine-grained personal access token with Contents: write scoped to the repo above.
# Create at: https://github.com/settings/personal-access-tokens/new
GITHUB_TOKEN=ghp_replace_me
